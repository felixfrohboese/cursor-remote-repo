# Required — transcription & speaker diarization (https://www.assemblyai.com/)
ASSEMBLYAI_API_KEY=

# Optional — enables the "Name speakers (AI)" button (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Optional — Claude model for speaker naming (default: claude-sonnet-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-5
